# AWS (us-east-1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Anthropic
ANTHROPIC_API_KEY=

# Discord bot tokens (Developer Portal → Bot → Token)
VESPER_NULL_DISCORD_TOKEN=
AMBER_DRIFT_DISCORD_TOKEN=

# Channels: #current-story is where the bots live (reactions, banter,
# mentions, emoji reactions); #theories gets occasional bigger-picture theory
# posts. EIGENTHROPE_CHANNEL_ID is the legacy single-channel fallback.
EIGENTHROPE_STORY_CHANNEL_ID=
EIGENTHROPE_THEORIES_CHANNEL_ID=

# AWS Secrets Manager *secret names* holding each bot's XRPL wallet seed
# (raw seed string, or JSON {"seed": "s..."})
VESPER_NULL_WALLET_SECRET=eigenthrope/vesper_null_wallet
AMBER_DRIFT_WALLET_SECRET=eigenthrope/amber_drift_wallet

# Game infrastructure
EIGENTHROPE_VAULT_ADDRESS=
EIGENTHROPE_S3_BUCKET=

# Optional overrides
# XRPL_WSS=wss://xrplcluster.com/
# CLAUDE_MODEL=claude-sonnet-4-6
# EIGENTHROPE_SITE_URL=https://eigenthrope.sjmorriswrites.com
